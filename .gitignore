# ── Build outputs ────────────────────────────────────────────────────────────
Binaries/
Cache/

# ── C++ intermediate files ───────────────────────────────────────────────────
*.obj
*.pdb
*.ilk
*.exp
*.lib
*.dll
*.exe
!Source/**/*.dll        # keep any vendored DLLs under Source/

# ── C# / .NET ────────────────────────────────────────────────────────────────
[Bb]in/
[Oo]bj/
*.user
*.suo
*.userosscache
*.sln.docstates
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets
packages/

# ── Generated project files (regenerated by GenerateProjectFiles.bat) ────────
JzRE.sln
Source/Runtime/*.vcxproj
Source/Runtime/*.vcxproj.filters
Source/Runtime/*.vcxproj.user

# ── Visual Studio ────────────────────────────────────────────────────────────
.vs/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.opendb
ipch/

# ── JetBrains Rider ──────────────────────────────────────────────────────────
.idea/
*.sln.iml

# ── VS Code ──────────────────────────────────────────────────────────────────
.vscode/

# ── Windows ──────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Logs & temp ──────────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
