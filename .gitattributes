# Normalize line endings: store LF in repo, checkout as CRLF on Windows
* text=auto

# Force CRLF on Windows batch scripts
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Force LF for shell scripts and Unix-style files
*.sh   text eol=lf

# Treat compiled binaries as binary (no line-ending conversion)
*.dll  binary
*.exe  binary
*.lib  binary
*.exp  binary
*.pdb  binary
*.obj  binary
