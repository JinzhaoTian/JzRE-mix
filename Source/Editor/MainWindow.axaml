<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JzRE.Editor"
        x:Class="JzRE.Editor.MainWindow"
        Title="JzRE-mix  |  Rendering Engine"
        Width="1280" Height="720"
        MinWidth="400" MinHeight="300">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Open OBJ Model…" Click="OnOpenFile" />
                <Separator />
                <MenuItem Header="Exit" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="Controls" Click="ShowControls" />
            </MenuItem>
        </Menu>
        <local:RenderControl Name="RenderHost" />
    </DockPanel>
</Window>
